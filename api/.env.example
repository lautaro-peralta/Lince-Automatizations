# ─── Variables de entorno del BACKEND (Express / Render) ───────────────────
# Copiá este archivo a `.env` (en local) y cargá las mismas claves en Render.
# Estos valores son SECRETOS del servidor: nunca se exponen al navegador.

# Puerto. Render lo inyecta solo; en local usa 3000 por defecto.
PORT=3000

# Conexión a Supabase.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# service-role key: acceso total a la base (bypassa RLS). MÁXIMO secreto.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreta

# Orígenes permitidos para CORS (la/s URL del frontend en Cloudflare Pages),
# separados por coma. Vacío = permite todo (cómodo solo en desarrollo).
FRONTEND_ORIGIN=http://localhost:5173

# ─── Comprobantes del Startup OS (subida de imágenes/PDF) ──────────────────
# Proveedor de almacenamiento: 'supabase' (activo) o 'uploadthing' (NO
# implementado todavía, ver api/src/lib/uploads.js).
UPLOADS_PROVIDER=supabase
# Nombre del bucket de Supabase Storage (crealo en Storage → New bucket).
SUPABASE_RECEIPTS_BUCKET=receipts
# Token de UploadThing: sin uso mientras UPLOADS_PROVIDER=supabase.
UPLOADTHING_TOKEN=

# ─── Notificaciones (TODAS opcionales) ─────────────────────────────────────
# Si no configurás ninguna, el server solo loguea el aviso por consola.
# Webhook genérico: recibe un POST JSON con cada aviso (Make/Zapier/Discord/
# Slack/un bridge de WhatsApp, etc.).
NOTIFY_WEBHOOK_URL=
# Email vía Resend (https://resend.com): necesitás la API key y el destino.
RESEND_API_KEY=
NOTIFY_EMAIL_FROM=Lince <onboarding@resend.dev>
NOTIFY_EMAIL_TO=

# ─── n8n (webhook de prospectos) ───────────────────────────────────────────
# POST /api/prospects dispara este webhook después de guardar en Supabase.
# Si no se configuran, el prospecto se guarda igual pero no se envía aviso.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# ─── IA (opcional) ─────────────────────────────────────────────────────────
# Para sugerir respuestas a reseñas con Claude. Sin la key, se usa una
# plantilla local. El modelo por defecto es claude-opus-4-8.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
