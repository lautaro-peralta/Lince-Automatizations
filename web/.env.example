# ─── Variables de entorno del FRONTEND (SvelteKit) ─────────────────────────
# Copiá este archivo a `.env` (en local) y cargá las mismas claves en Vercel.
# Solo las variables con prefijo PUBLIC_ se exponen al navegador. NUNCA pongas
# acá secretos del servidor (como la service-role key de Supabase).

# URL del backend (Express en Render). En local apuntá al server local.
PUBLIC_API_URL=http://localhost:3000

# Datos de Supabase usados SOLO por el panel admin (login).
# La anon key está diseñada para ser pública (la protege RLS).
PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica
