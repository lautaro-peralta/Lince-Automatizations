# Cabeceras que Cloudflare Pages aplica a los assets estáticos y páginas
# prerenderizadas (el adapter copia este archivo a la salida del build).
# Las respuestas dinámicas del Worker las cubre src/hooks.server.ts.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# El panel interno no debe indexarse en buscadores.
/admin/*
  X-Robots-Tag: noindex
