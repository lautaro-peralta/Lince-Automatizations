# Cabeceras que Cloudflare Pages aplica a los assets estáticos y páginas
# prerenderizadas (el adapter copia este archivo a la salida del build).
# Las respuestas dinámicas del Worker las cubre src/hooks.server.ts.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# El panel interno no debe indexarse en buscadores.
/admin/*
  X-Robots-Tag: noindex

# El Startup OS es una herramienta interna: tampoco se indexa.
/startup-os/*
  X-Robots-Tag: noindex

# Lince Teams es una herramienta interna: tampoco se indexa.
/teams/*
  X-Robots-Tag: noindex

# Librerías vendoreadas con la versión en el nombre: cache inmutable.
/startup-os/vendor/*
  Cache-Control: public, max-age=31536000, immutable

/teams/vendor/*
  Cache-Control: public, max-age=31536000, immutable
